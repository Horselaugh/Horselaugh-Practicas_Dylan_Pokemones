<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pokemon_list" model="ir.ui.view">
        <field name="name">pokemon.list</field>
        <field name="model">pokemon.Pokemon</field>
        <field name="arch" type="xml">
            <list string="Pokédex" decoration-info="state == 'loose'" decoration-success="state == 'caught'">
                <field name="image" widget="image" options="{'size': [40, 40]}" class="oe_avatar"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="state" widget="badge" decoration-success="caught" decoration-info="loose"/>
            </list>
        </field>
    </record>

    <record id="view_pokemon_form" model="ir.ui.view">
        <field name="name">pokemon.form</field>
        <field name="model">pokemon.Pokemon</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="load_pokemon" 
                            string="Cargar desde PokéAPI" 
                            type="object" 
                            class="oe_highlight" 
                            confirm="¿Deseas importar los 151 Pokémon? Esto puede tardar unos segundos."/>
                    
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del Pokémon..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" options="{'no_create': True, 'no_open': False}"/>
                        </group>
                        <group>
                            </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pokemon" model="ir.actions.act_window">
        <field name="name">Pokémon</field>
        <field name="res_model">pokemon</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡No hay Pokémon registrados!
            </p>
            <p>
                Haz clic en "Cargar desde PokéAPI" para llenar tu base de datos.
            </p>
        </field>
    </record>

</odoo>