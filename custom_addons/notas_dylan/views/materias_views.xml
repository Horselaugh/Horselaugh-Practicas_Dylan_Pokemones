<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="view_materias_tree" model="ir.ui.view">
            <field name="name">notas.materias.tree</field>
            <field name="model">notas_dylan.materias</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" string="Nombre"/>
                </list>
            </field>
        </record>
    </data>
</odoo>

<odoo>
    <data>
        <record id="view_materias_form" model="ir.ui.view">
            <field name="name">notas.materias.form</field>
            <field name="model">notas_dylan.materias</field>
            <field name="arch" type="xml">
                <form>
                    <field name="name" string="Nombre"/>
                    <field name="description" string="Descripcion"/>
                    <field name="grades" string="Notas"/>
                    <field name="to_do" string="Tareas"/>
                    <field name="to_do_date" string="Fecha de entrega"/>
                    <field name="state" string="Estado"/>
                    <field name="materias_user" string="Usuarios de esta materia"/>
                </form>
            </field>
        </record>
    </data>
</odoo>