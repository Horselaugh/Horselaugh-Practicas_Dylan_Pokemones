<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista list (Lista) para Products -->
        <record id="view_product_list" model="ir.ui.view">
            <field name="name">ecommerce.product.list</field>
            <field name="model">ecommerce.ecommerce</field>
            <field name="arch" type="xml">
                <list string="Lista de Productos">
                    <field name="name"/>
                    <field name="price"/>
                    <field name="category"/>
                </list>
            </field>
        </record>
    </data>
</odoo>