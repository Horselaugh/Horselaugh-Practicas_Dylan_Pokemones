<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista List para Clientes -->
        <record id="view_cliente_list" model="ir.ui.view">
            <field name="name">ecommerce.cliente.list</field>
            <field name="model">ecommerce.cliente</field>
            <field name="arch" type="xml">
                <list string="Clientes">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                </list>
            </field>
        </record>
        
        <!-- Vista Form para Clientes -->
        <record id="view_cliente_form" model="ir.ui.view">
            <field name="name">ecommerce.cliente.form</field>
            <field name="model">ecommerce.cliente</field>
            <field name="arch" type="xml">
                <form string="Cliente">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>