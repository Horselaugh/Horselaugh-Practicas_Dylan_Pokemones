<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ACCIÓN PARA PRODUCTOS -->
        <record id="action_ecommerce_product" model="ir.actions.act_window">
            <field name="name">Productos</field>
            <field name="res_model">ecommerce.producto_api</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cargar productos desde la API
                </p>
            </field>
        </record>

        <!-- Vista lista para Productos -->
        <record id="view_product_list" model="ir.ui.view">
            <field name="name">ecommerce.producto_api.list</field>
            <field name="model">ecommerce.producto_api</field>
            <field name="arch" type="xml">
                <list string="Lista de Productos">
                    <field name="name"/>
                    <field name="price"/>
                    <field name="category"/>
                </list>
            </field>
        </record>

        <!-- Vista formulario para Productos -->
        <record id="view_product_form" model="ir.ui.view">
            <field name="name">ecommerce.producto_api.form</field>
            <field name="model">ecommerce.producto_api</field>
            <field name="arch" type="xml">
                <form string="Producto">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="category"/>
                            <field name="description"/>
                            <field name="image" widget="url"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>