<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista list (Lista) para Pokémon -->
        <record id="view_pokemon_list" model="ir.ui.view">
            <field name="name">pokemon.pokemon.list</field>
            <field name="model">pokemon.pokemon</field>
            <field name="arch" type="xml">
                <list string="Pokémon Disponibles">
                    <field name="pokedex_number" string="N°"/>
                    <field name="name" string="Nombre"/>
                    <field name="types" string="Tipos"/>
                    <field name="height" string="Altura"/>
                    <field name="weight" string="Peso"/>
                    <field name="base_experience" string="Exp. Base"/>
                </list>
            </field>
        </record>
    </data>
</odoo>