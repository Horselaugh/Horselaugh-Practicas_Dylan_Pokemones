<!-- captura_pokemon_views.xml -->
<odoo>
    <data>
        <!-- Form View para Captura -->
        <record id="view_captura_form" model="ir.ui.view">
            <field name="name">pokemon.captura.form</field>
            <field name="model">pokemon.captura</field>
            <field name="arch" type="xml">
                <form string="Captura de Pokémon">
                    <header>
                        <button name="unlink" string="Liberar Pokémon" states="capturado" type="object" class="btn-danger" confirm="¿Está seguro de liberar este Pokémon?"/>
                        <field name="estado" widget="statusbar" statusbar_visible="capturado,liberado"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="entrenador_id" context="{'search_default_active': 1}"/>
                                <field name="entrenador_nombre" readonly="1"/>
                            </group>
                            <group>
                                <field name="pokemon_id" context="{'search_default_available': 1}"/>
                                <field name="pokemon_name" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="fecha_captura"/>
                                <field name="estado"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View para Captura -->
        <record id="view_captura_tree" model="ir.ui.view">
            <field name="name">pokemon.captura.tree</field>
            <field name="model">pokemon.captura</field>
            <field name="arch" type="xml">
                <tree string="Capturas de Pokémon" decoration-success="estado=='capturado'" decoration-danger="estado=='liberado'">
                    <field name="entrenador_nombre"/>
                    <field name="pokemon_name"/>
                    <field name="fecha_captura"/>
                    <field name="estado"/>
                </tree>
            </field>
        </record>

        <!-- Search View para Captura -->
        <record id="view_captura_search" model="ir.ui.view">
            <field name="name">pokemon.captura.search</field>
            <field name="model">pokemon.captura</field>
            <field name="arch" type="xml">
                <search string="Buscar Capturas">
                    <field name="entrenador_id"/>
                    <field name="pokemon_id"/>
                    <field name="estado"/>
                    <filter name="capturados" string="Capturados" domain="[('estado','=','capturado')]"/>
                    <filter name="liberados" string="Liberados" domain="[('estado','=','liberado')]"/>
                    <separator/>
                    <filter name="group_by_entrenador" string="Agrupar por Entrenador" context="{'group_by':'entrenador_id'}"/>
                    <filter name="group_by_pokemon" string="Agrupar por Pokémon" context="{'group_by':'pokemon_id'}"/>
                </search>
            </field>
        </record>
    </data>
</odoo>