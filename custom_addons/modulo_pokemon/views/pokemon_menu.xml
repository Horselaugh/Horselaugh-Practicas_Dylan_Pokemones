<!-- pokemon_menu.xml -->
<odoo>
    <data>
        <!-- Acciones de Ventana -->
        <record id="action_entrenador" model="ir.actions.act_window">
            <field name="name">Entrenadores Pokémon</field>
            <field name="res_model">pokemon.entrenador</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
            </field>
        </record>

        <record id="action_pokemon" model="ir.actions.act_window">
            <field name="name">Pokémon</field>
            <field name="res_model">pokemon.pokemon</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Carga Pokémon desde la API o crea nuevos manualmente
                </p>
            </field>
        </record>

        <record id="action_captura" model="ir.actions.act_window">
            <field name="name">Capturas de Pokémon</field>
            <field name="res_model">pokemon.captura</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Registra nuevas capturas de Pokémon
                </p>
            </field>
        </record>

        <!-- Menús -->
        <menuitem id="menu_pokemon_root" name="Pokémon" sequence="10"/>
        
        <menuitem id="menu_pokemon_entrenadores" name="Entrenadores" 
                  parent="menu_pokemon_root" action="action_entrenador" sequence="10"/>
        
        <menuitem id="menu_pokemon_pokemon" name="Pokémon" 
                  parent="menu_pokemon_root" action="action_pokemon" sequence="20"/>
        
        <menuitem id="menu_pokemon_capturas" name="Capturas" 
                  parent="menu_pokemon_root" action="action_captura" sequence="30"/>
    </data>
</odoo>