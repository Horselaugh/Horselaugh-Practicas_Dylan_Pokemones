{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug Odoo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/odoo-18.0.post20251118/odoo-18.0.post20251118/odoo-bin",
            "args": [
                "-c",
                "${workspaceFolder}/odoo.conf",
                "--dev=all",
                "--limit-time-real",
                "99999"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}
